{
  "name": "rpg-runner-functions",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "corepack pnpm run build && firebase emulators:start --only functions,firestore",
