    "test": "echo \"No backend tests configured yet.\""
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.8.3"
  }
}
